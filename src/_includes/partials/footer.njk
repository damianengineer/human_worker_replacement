<footer class="site-footer">
  <nav class="site-footer__sitemap" aria-label="Sitemap">
    {% for group in site.footer.groups %}
    <div class="site-footer__group">
      <h2 class="site-footer__heading">{{ group.heading }}</h2>
      <ul class="site-footer__list">
        {% for link in group.links %}
        <li>
          <a href="{{ link.url }}">{{ link.label }}</a>
          {% if link.note %}<span class="site-footer__note">{{ link.note }}</span>{% endif %}
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
  </nav>
  <p class="site-footer__copyright">{{ site.footer.copyright }}</p>
</footer>
