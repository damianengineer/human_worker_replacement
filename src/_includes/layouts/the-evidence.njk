---
layout: "layouts/base.njk"
extraCss:
  - "/assets/css/the-evidence.css"
---
{% import "partials/figures.njk" as figures with context %}

{% macro dualSourceLine(primary, corroborating, note) %}
{% if primary %}
<p class="evidence-list__source">{{ primary | citeLink | safe }}{% if corroborating %}, {{ corroborating | citeLink | safe }}{% endif %}</p>
{% else %}
<p class="evidence-list__source evidence-list__source--missing">Source: citation needed</p>
{% endif %}
{% if note %}<p class="evidence-list__note">{{ note }}</p>{% endif %}
{% endmacro %}

{% macro citeList(ids) %}{% for id in ids %}{{ id | citeLink | safe }}{% if not loop.last %}, {% endif %}{% endfor %}{% endmacro %}

{% macro statCallout(callout) %}
{% if callout %}
<div class="stat-callout">
  <p class="stat-callout__numeral">{{ callout.numeral }}</p>
  <p class="stat-callout__label">{{ callout.label }}</p>
  <p class="stat-callout__source">{{ citeList(callout.citations) }}</p>
</div>
{% endif %}
{% endmacro %}

{% macro pullQuote(text, ids) %}
{% if text %}
<blockquote class="pull-quote">
  <p>{{ text }}</p>
  <footer class="pull-quote__attribution">{{ citeList(ids) }}</footer>
</blockquote>
{% endif %}
{% endmacro %}

{% macro figuresGrid(figuresList, figuresIntro, closeHref) %}
{% if figuresList %}
{% if figuresIntro %}
<p class="evidence-figures-intro">{{ figuresIntro }}</p>
{% endif %}
<div class="evidence-figures">
  {% for figure in figuresList %}
  <figure class="evidence-figure">
    <a class="evidence-figure__zoom" href="#fig-{{ figure.id }}" aria-label="View a larger version of: {{ figure.title }}">
      <img src="{{ figure.image }}" alt="{{ figure.alt }}" loading="lazy">
    </a>
    {{ figures.figureCredit(figure.title, figure.citation, figure.credit) }}
  </figure>
  {% endfor %}
</div>
{% for figure in figuresList %}
<div class="evidence-lightbox" id="fig-{{ figure.id }}">
  <a class="evidence-lightbox__backdrop" href="{{ closeHref }}" aria-label="Close larger image"></a>
  <div class="evidence-lightbox__content">
    <a class="evidence-lightbox__close" href="{{ closeHref }}" aria-label="Close larger image">Close ✕</a>
    <img src="{{ figure.image }}" alt="{{ figure.alt }}">
  </div>
</div>
{% endfor %}
{% endif %}
{% endmacro %}

<h1>{{ title }}</h1>

<div class="evidence-intro">
  {{ content | safe }}
</div>

{% if teaser_label and teaser_url %}
<p class="evidence-teaser">
  <a class="evidence-teaser__link" href="{{ teaser_url }}">{{ teaser_label }}</a>
</p>
{% endif %}

<section class="evidence-section" id="current-state" aria-labelledby="current-state-heading">
  <h2 id="current-state-heading">{{ evidence.current_state.title }}</h2>
  <p class="evidence-section__intro">{{ evidence.current_state.intro }}</p>
  <ul class="evidence-list">
    {% for item in evidence.current_state.items %}
    <li class="evidence-list__item">
      <p>{{ item.claim | safe }}</p>
      {{ statCallout(item.stat_callout) }}
      {# An item with a stat_callout always cites the same source(s) inside
         the callout box as its own primary/corroborating_citation — the
         callout already shows the marker, so the line below only needs to
         add the note, not repeat the same citation a second time. #}
      {% if item.stat_callout %}
      {% if item.note %}<p class="evidence-list__note">{{ item.note }}</p>{% endif %}
      {% else %}
      {{ dualSourceLine(item.primary_citation, item.corroborating_citation, item.note) }}
      {% endif %}
      {% if item.example %}
      <aside class="evidence-example">
        <p class="evidence-example__label">What this looks like in practice</p>
        <p>{{ item.example }}</p>
      </aside>
      {% endif %}
    </li>
    {% endfor %}
  </ul>
</section>

<section class="evidence-section" id="at-risk" aria-labelledby="at-risk-heading">
  <h2 id="at-risk-heading">{{ evidence.at_risk.title }}</h2>

  {% set tvo = evidence.at_risk.theoretical_vs_observed %}
  <div class="evidence-subsection">
    <h3>{{ tvo.heading }}</h3>
    <p class="evidence-section__intro">{{ tvo.concept }}</p>

    {% if tvo.example %}
    <aside class="evidence-subsection-example">
      <p class="evidence-subsection-example__label">{{ tvo.example.heading }}</p>
      <p>{{ tvo.example.text }}</p>
      <p class="evidence-list__source">{{ citeList(tvo.example.citations) }}</p>
    </aside>
    {% endif %}

    {% if tvo.methodology_note %}
    <p class="evidence-methodology-note">
      {{ tvo.methodology_note }}
      {% for id in tvo.methodology_citations %}{{ id | citeLink | safe }}{% if not loop.last %}, {% endif %}{% endfor %}
    </p>
    {% endif %}

    {{ figuresGrid(tvo.figures, tvo.figures_intro, "#at-risk") }}
  </div>

  {% set exposed = evidence.at_risk.most_exposed %}
  <div class="evidence-subsection">
    <h3>{{ exposed.heading }}</h3>
    {% for para in exposed.intro %}<p class="evidence-section__intro">{{ para }}</p>{% endfor %}

    {% if exposed.section_citations %}
    <p class="evidence-section__source-note">
      Sources for every occupation below: {{ exposed.section_citations.primary_citation | citeLink | safe }}, corroborated by {{ exposed.section_citations.corroborating_citation | citeLink | safe }}.
    </p>
    {% endif %}

    <ul class="evidence-list evidence-list--two-col evidence-list--compact">
      {% for item in exposed.items %}
      <li class="evidence-list__item evidence-list__item--compact">
        <p><strong>{{ item.industry }}</strong> — {{ item.risk_summary }}{% if item.note %} <span class="evidence-list__note-inline">{{ item.note | safe }}</span>{% endif %}</p>
        {% if item.primary_citation or not exposed.section_citations %}
        {{ dualSourceLine(item.primary_citation, item.corroborating_citation, null) }}
        {% endif %}
      </li>
      {% endfor %}
    </ul>

    {{ figuresGrid(exposed.figures, exposed.figures_intro, "#at-risk") }}
  </div>

  {% set stark = evidence.at_risk.stark_state %}
  <div class="evidence-subsection" id="stark-state">
    <h3>{{ stark.heading }}</h3>
    <p class="evidence-section__intro">{{ stark.intro }}</p>
    <p class="evidence-list__source">{{ stark.citation | citeLink | safe }}</p>

    {% for group in stark.confidence_groups %}
    <details class="evidence-confidence-group evidence-confidence-group--{{ group.key }}">
      <summary class="evidence-confidence-group__summary">
        {{ group.label }}
        <span class="evidence-confidence-group__count">({{ group.programs.length }} program{% if group.programs.length != 1 %}s{% endif %})</span>
      </summary>
      <p class="evidence-confidence-group__description">{{ group.description }}</p>
      <ul class="evidence-program-list">
        {% for program in group.programs %}
        <li>{{ program.name }}{% if program.note %} <span class="evidence-program-list__note">— {{ program.note }}</span>{% endif %}</li>
        {% endfor %}
      </ul>
    </details>
    {% endfor %}
  </div>
</section>

<section class="evidence-section" id="protective-factors" aria-labelledby="protective-factors-heading">
  <h2 id="protective-factors-heading">{{ evidence.protective_factors.title }}</h2>
  {{ statCallout(evidence.protective_factors.callout) }}

  {{ figures.singleFigure(evidence.protective_factors.lead_figure, "#protective-factors") }}

  {% set outlook = evidence.protective_factors.outlook %}
  {% for barrier in evidence.protective_factors.barriers %}
  <div class="evidence-barrier">
    <h3>{{ barrier.heading }}</h3>
    <p>{{ barrier.explanation }}</p>
    <p class="evidence-barrier__jobs"><strong>Jobs protected by this barrier:</strong> {{ barrier.protected_jobs }}</p>
    {{ statCallout(barrier.stat_callout) }}
    {# Same reasoning as current_state's items above: a barrier with a
       stat_callout cites the same source(s) inside the callout box as its
       own citations field, so skip the redundant line below. #}
    {% if not barrier.stat_callout %}
    <p class="evidence-list__source">{{ citeList(barrier.citations) }}</p>
    {% endif %}
  </div>
  {% if outlook and outlook.after_barrier == loop.index %}
  <div class="evidence-barrier evidence-barrier--outlook">
    <h3>{{ outlook.heading }}</h3>
    <p>{{ outlook.text }}</p>
    <p class="evidence-list__source">{{ citeList(outlook.citations) }}</p>
  </div>
  {% endif %}
  {% endfor %}
</section>

<section class="evidence-section" id="counterarguments" aria-labelledby="counterarguments-heading">
  <h2 id="counterarguments-heading">{{ evidence.counterarguments.title }}</h2>
  <p class="evidence-section__intro">{{ evidence.counterarguments.intro }}</p>
  {{ statCallout(evidence.counterarguments.callout) }}

  {% for point in evidence.counterarguments.points %}
  <div class="evidence-counter-point">
    <h3>{{ point.heading }}</h3>
    {% for para in point.paragraphs %}<p>{{ para }}</p>{% endfor %}
    {{ pullQuote(point.pull_quote, point.citations) }}
    {% if point.sub_points %}
    <ul class="evidence-list-plain">
      {% for sp in point.sub_points %}<li>{{ sp }}</li>{% endfor %}
    </ul>
    {% endif %}
    {% if point.closing %}<p>{{ point.closing }}</p>{% endif %}
    {% if point.callout %}<p class="evidence-callout">{{ point.callout }}</p>{% endif %}
    <p class="evidence-list__source">{{ citeList(point.citations) }}</p>
  </div>
  {% endfor %}

  {% set outro = evidence.counterarguments.outro %}
  {% if outro %}
  <div class="evidence-counter-point evidence-counter-point--outro">
    <h3>{{ outro.heading }}</h3>
    <p>{{ outro.text }}</p>
  </div>
  {% endif %}
</section>

{% if outro_text and outro_links %}
<p class="evidence-outro">
  {{ outro_text }}
  {% for link in outro_links %}<a class="evidence-outro__link" href="{{ link.url }}">{{ link.label }}</a>{% if not loop.last %} · {% endif %}{% endfor %}
</p>
{% endif %}
