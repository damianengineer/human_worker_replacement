---
layout: "layouts/base.njk"
extraCss:
  - "/assets/css/home.css"
  - "/assets/css/the-evidence.css"
---
{% import "partials/figures.njk" as figures with context %}

<h1>{{ title }}</h1>

<div class="home-intro">
  {{ content | safe }}
</div>

<section class="home-section" id="short-version" aria-labelledby="short-version-heading">
  <h2 id="short-version-heading">{{ home.short_version.heading }}</h2>
  <p>{{ home.short_version.text }}</p>
  <p class="home-section__source">
    {% for id in home.short_version.citations %}{{ id | citeLink | safe }}{% if not loop.last %}, {% endif %}{% endfor %}
  </p>
  {{ figures.singleFigure(home.short_version.figure, "#short-version") }}
  <p><a href="{{ home.short_version.link_url }}">{{ home.short_version.link_label }}</a></p>
</section>

<section class="home-section" id="timeline" aria-labelledby="timeline-heading">
  <h2 id="timeline-heading">{{ home.timeline.heading }}</h2>
  <p>{{ home.timeline.intro }}</p>
  <ol class="home-timeline">
    {% for era in home.timeline.eras %}
    <li class="home-timeline__card">
      {% if era.image %}
      <div class="home-timeline__image-wrap">
        <img class="home-timeline__image" src="{{ era.image }}" alt="{{ era.image_alt }}" width="{{ era.image_width }}" height="{{ era.image_height }}" loading="lazy">
      </div>
      <p class="home-timeline__credit">{{ era.image_credit }} — {{ era.image_citation | citeLink | safe }}</p>
      {% endif %}
      <p class="home-timeline__label">{{ era.label }}</p>
      <span class="home-timeline__tag{% if era.certainty == 'Forecast — contested' or era.certainty == 'Speculative' %} home-timeline__tag--caution{% endif %}">{{ era.certainty }}</span>
      <p>{{ era.text }}</p>
      <p><a href="{{ era.link_url }}">{{ era.link_label }}</a></p>
    </li>
    {% endfor %}
  </ol>
</section>

<section class="home-section" id="where-to-go" aria-labelledby="where-to-go-heading">
  <h2 id="where-to-go-heading">{{ home.where_to_go.heading }}</h2>
  <p>{{ home.where_to_go.intro }}</p>
  <div class="home-clocks">
    {% for group in home.where_to_go.groups %}
    <div class="home-clocks__group">
      <h3>{{ group.heading }}</h3>
      <ul class="home-list">
        {% for item in group.items %}
        <li class="home-list__item">
          <p><strong>{{ item.lead }}</strong><br>{{ item.text | safe }}</p>
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
  </div>
</section>

<p class="home-closing">{{ home.closing.text | safe }}</p>
