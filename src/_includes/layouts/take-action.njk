---
layout: "layouts/base.njk"
extraCss:
  - "/assets/css/take-action.css"
---
{% macro takeactionItem(item) %}
<li class="takeaction-item{% if item.advanced %} takeaction-item--advanced{% endif %}">
  <p>{{ item.text | safe }}</p>

  {% set previewLinks = item.links | withImage %}
  {% if previewLinks.length %}
  <div class="takeaction-item__previews">
    {% for link in previewLinks %}
    <a class="takeaction-preview" href="{{ link.url }}">
      <img src="{{ link.image }}" alt="Video thumbnail: {{ link.label }}" loading="lazy">
      <span class="takeaction-preview__label">{{ link.label }}</span>
    </a>
    {% endfor %}
  </div>
  {% endif %}

  {% set embedLinks = item.links | withEmbed %}
  {% if embedLinks.length %}
  <div class="takeaction-item__embeds">
    {% for link in embedLinks %}
    <div class="takeaction-embed">
      {% youtubeEmbed link.embed_video_id, link.label %}
      <span class="takeaction-embed__label">{{ link.label }}</span>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% set textLinks = item.links | withoutImage %}
  {% if item.citations.length or textLinks.length %}
  <p class="takeaction-item__extras">
    {% for id in item.citations %}{{ id | citeLink | safe }}{% if not loop.last %}; {% endif %}{% endfor %}
    {% if item.citations.length and textLinks.length %}; {% endif %}
    {% for link in textLinks %}<a href="{{ link.url }}">{{ link.label }}</a>{% if not loop.last %}; {% endif %}{% endfor %}
  </p>
  {% endif %}
</li>
{% endmacro %}

<h1>{{ title }}</h1>

<div class="takeaction-intro">
  {{ content | safe }}
</div>

<nav class="takeaction-jump" aria-label="Sections on this page">
  <ul>
    {% for cta in takeaction.ctas %}
    <li><a href="#{{ cta.key | slugify }}">{{ cta.heading }}</a></li>
    {% endfor %}
  </ul>
</nav>

{% for cta in takeaction.ctas %}
<section class="takeaction-section" id="{{ cta.key | slugify }}" aria-labelledby="{{ cta.key | slugify }}-heading">
  <h2 id="{{ cta.key | slugify }}-heading">{% if cta.icon %}<span aria-hidden="true">{{ cta.icon }}</span> {% endif %}{{ cta.heading }}</h2>

  {% if cta.debate %}
  {% set debate = cta.debate %}
  <div class="takeaction-debate">
    <h3 id="policy-debate">{{ debate.heading }}</h3>
    <p class="takeaction-debate__intro">{{ debate.intro }}</p>
    <div class="takeaction-debate__cards">
      {% for proposal in debate.proposals %}
      <div class="takeaction-debate__card">
        <h4>{{ proposal.name }}</h4>
        <p class="takeaction-debate__what">{{ proposal.what }}</p>
        <p class="takeaction-debate__for"><strong>The case for:</strong> {{ proposal.case_for }}</p>
        <p class="takeaction-item__extras">
          {% for id in proposal.citations %}{{ id | citeLink | safe }}{% if not loop.last %}; {% endif %}{% endfor %}
        </p>
        <p class="takeaction-debate__against"><strong>The case against:</strong> {{ proposal.case_against }}</p>
        <p class="takeaction-item__extras">
          {% for id in proposal.counter_citations %}{{ id | citeLink | safe }}{% if not loop.last %}; {% endif %}{% endfor %}
        </p>
      </div>
      {% endfor %}
    </div>
    <p class="takeaction-debate__landing">{{ debate.landing }}</p>
  </div>
  {% endif %}

  {% if cta.resource_groups %}
    <nav class="takeaction-subnav" aria-label="Jump to a resource type">
      <ul>
        {% for group in cta.resource_groups %}
        <li><a href="#{{ cta.key | slugify }}-{{ group.type | slugify }}">{{ group.type }}</a></li>
        {% endfor %}
        {% if cta.caution_section %}
        <li><a href="#{{ cta.key | slugify }}-caution-heading">{{ cta.caution_section.heading }}</a></li>
        {% endif %}
      </ul>
    </nav>

    {% if cta.intro_items %}
    <ul class="takeaction-list">
      {% for item in cta.intro_items %}{{ takeactionItem(item) }}{% endfor %}
    </ul>
    {% endif %}

    {% for group in cta.resource_groups %}
    <div class="takeaction-subsection" id="{{ cta.key | slugify }}-{{ group.type | slugify }}">
      <h3>{{ group.type }}</h3>
      {% if group.items.length %}
      <ul class="takeaction-list">
        {% for item in group.items %}{{ takeactionItem(item) }}{% endfor %}
      </ul>
      {% else %}
      <p class="takeaction-list__empty">{{ group.empty_note }}</p>
      {% endif %}
    </div>
    {% endfor %}

    {% if cta.outro_items %}
    <ul class="takeaction-list">
      {% for item in cta.outro_items %}{{ takeactionItem(item) }}{% endfor %}
    </ul>
    {% endif %}

    {% if cta.caution_section %}
    {% set caution = cta.caution_section %}
    <div class="takeaction-caution" role="note" aria-labelledby="{{ cta.key | slugify }}-caution-heading">
      <h3 id="{{ cta.key | slugify }}-caution-heading" class="takeaction-caution__heading">
        <span aria-hidden="true">⚠️</span> {{ caution.heading }}
      </h3>
      {% for para in caution.intro %}<p class="takeaction-caution__intro">{{ para }}</p>{% endfor %}
      <ul class="takeaction-list">
        {% for item in caution.items %}{{ takeactionItem(item) }}{% endfor %}
      </ul>
    </div>
    {% endif %}
  {% else %}
  <ul class="takeaction-list">
    {% for item in cta.items %}{{ takeactionItem(item) }}{% endfor %}
  </ul>
  {% endif %}
</section>
{% endfor %}
