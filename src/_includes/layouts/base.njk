<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title == site.title %}{{ title }}{% else %}{{ title }} | {{ site.title }}{% endif %}</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}

  {# CSP/referrer meta-tag fallback (CLAUDE.md Section 8). X-Content-Type-Options
     and Permissions-Policy can only be set via a real HTTP header, not a meta
     tag — that still needs to be configured in the GitHub Pages deploy step.
     frame-src is scoped to exactly one third-party origin (YouTube's
     privacy-enhanced embed domain) for the video embeds on /take-action/ —
     this is the one explicitly-requested third-party embed on the site
     (CLAUDE.md Section 8's "never silently add third-party embeds" bar),
     not a general allowance for arbitrary iframes. #}
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; img-src 'self'; style-src 'self'; script-src 'self'; frame-src https://www.youtube-nocookie.com; base-uri 'none'; form-action 'self'">
  <meta name="referrer" content="strict-origin-when-cross-origin">

  {# Preloads the one weight guaranteed to render above the fold on every
     page (the header brand + every h1 use font-weight 700). The 500
     weight (journey-pager label) isn't preloaded — it's below the fold
     on every page it appears. Same-origin file, but browsers still
     require the preload hint to fetch it early instead of waiting on
     tokens.css to parse. #}
  <link rel="preload" href="/assets/fonts/SpaceGrotesk-Bold.woff2" as="font" type="font/woff2" crossorigin>

  <link rel="stylesheet" href="/assets/css/tokens.css">
  <link rel="stylesheet" href="/assets/css/base.css">
  {% for href in extraCss %}
  <link rel="stylesheet" href="{{ href }}">
  {% endfor %}
</head>
<body>
  <a class="skip-link" href="#main">Skip to main content</a>

  {% include "partials/site-chrome-top.njk" %}

  <main id="main">
    {{ content | safe }}
    {%- include "partials/pager.njk" -%}
  </main>

  {% include "partials/footer.njk" %}
</body>
</html>
